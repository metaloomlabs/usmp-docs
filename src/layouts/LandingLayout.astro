---
import '../styles/global.css';
import BackgroundNetwork from '../components/BackgroundNetwork.astro';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "USMP | Unified Secure Multi-transport Protocol", 
  description = "Secure, lightweight, transport-agnostic communication protocol for embedded devices" 
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/assets/favicon.png`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/assets/logo.png`} />

    <script is:inline>
      const theme = localStorage.getItem('theme') || 'light';
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>
  <body class="bg-bg-dark min-h-screen flex flex-col relative antialiased transition-colors duration-300">
    <!-- Animated Network Background -->
    <div class="hidden dark:block">
      <BackgroundNetwork />
    </div>

    <div class="flex-1 flex flex-col relative z-10">
      <!-- Header -->
      <header class="sticky top-0 z-50 h-16 border-b border-border-subtle bg-bg-panel/75 backdrop-blur-md transition-colors duration-300">
        <div class="max-w-[1200px] h-full mx-auto px-6 flex items-center justify-between">
          <a href={import.meta.env.BASE_URL} class="flex items-center gap-3 text-text-heading font-heading font-bold text-lg no-underline">
            <img src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/assets/logo.png`} alt="USMP Logo" class="h-8 w-8 object-contain" />
            <span class="tracking-wide">USMP</span>
          </a>
          
          <nav class="hidden sm:flex items-center gap-8">
            <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/docs`} class="text-sm font-semibold text-text-primary hover:text-text-heading transition-colors no-underline">Documentation</a>
            <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/docs/spec`} class="text-sm font-semibold text-text-primary hover:text-text-heading transition-colors no-underline">Specification</a>
            <a 
              href="https://github.com/metaloomlabs/usmp" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="text-sm font-semibold text-text-primary hover:text-text-heading transition-colors flex items-center gap-1.5 no-underline"
            >
              GitHub
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
            </a>
          </nav>

          <div class="flex items-center gap-4">
            <!-- Theme Toggle -->
            <button id="theme-toggle" class="bg-transparent border border-border-subtle hover:border-text-heading text-text-primary hover:text-text-heading w-9 h-9 rounded-lg flex items-center justify-center cursor-pointer transition-all duration-300" aria-label="Toggle dark mode">
              <svg class="sun-icon hidden dark:block" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"></path><path d="M12 20v2"></path><path d="M4.93 4.93l1.41 1.41"></path><path d="M17.66 17.66l1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="M6.34 17.66l-1.41 1.41"></path><path d="M19.07 4.93l-1.41 1.41"></path></svg>
              <svg class="moon-icon block dark:hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path></svg>
            </button>
            <a 
              href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/docs`} 
              class="px-4 py-2 bg-text-heading text-bg-panel font-semibold rounded-lg text-sm hover:opacity-90 transition-opacity duration-300 no-underline"
            >
              Control Center
            </a>
          </div>
        </div>
      </header>

      <slot />

      <!-- Footer -->
      <footer class="border-t border-border-subtle bg-bg-panel/40 py-10 mt-auto">
        <div class="max-w-[1200px] mx-auto px-6 flex flex-col sm:flex-row justify-between items-center gap-4 text-sm text-text-primary font-mono">
          <p>USMP_PROJECT &copy; 2026. RELEASED UNDER MIT LICENSE.</p>
          <div class="flex gap-6">
            <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/docs`} class="hover:text-text-heading transition-colors no-underline">DOCS</a>
            <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/docs/spec`} class="hover:text-text-heading transition-colors no-underline">SPEC</a>
            <a href="https://github.com/metaloomlabs/usmp" target="_blank" rel="noopener noreferrer" class="hover:text-text-heading transition-colors no-underline">GITHUB</a>
          </div>
        </div>
      </footer>
    </div>

    <!-- Theme Switcher -->
    <script>
      const themeToggle = document.getElementById('theme-toggle');
      if (themeToggle) {
        themeToggle.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
      }
    </script>
  </body>
</html>
