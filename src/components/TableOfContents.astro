---
interface Props {
  headings?: { depth: number; slug: string; text: string }[];
}

const { headings = [] } = Astro.props;

// Filter headings to show only h2 and h3
const filteredHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{filteredHeadings.length > 0 && (
  <nav class="toc-nav">
    <h4 class="toc-title">On This Page</h4>
    <ul class="toc-list" id="toc-list">
      {filteredHeadings.map((h) => (
        <li class={`toc-item depth-${h.depth}`}>
          <a href={`#${h.slug}`} class="toc-link" data-slug={h.slug}>
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<!-- TOC Active Highlight Script -->
<script>
  const observerOptions = {
    root: null,
    rootMargin: '-100px 0px -66%',
    threshold: 1.0,
  };

  const headings = Array.from(document.querySelectorAll('.prose h2, .prose h3'));
  const tocLinks = document.querySelectorAll('.toc-link');

  if (headings.length > 0 && tocLinks.length > 0) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          tocLinks.forEach((link) => {
            if (link.getAttribute('data-slug') === id) {
              link.classList.add('active');
            } else {
              link.classList.remove('active');
            }
          });
        }
      });
    }, observerOptions);

    headings.forEach((heading) => observer.observe(heading));
  }
</script>

<style>
  .toc-nav {
    position: sticky;
    top: calc(var(--header-height) + 2rem);
    height: calc(100vh - var(--header-height) - 4rem);
    width: 100%;
    overflow-y: auto;
    border-left: 1px solid var(--border-color);
    padding-left: 1rem;
  }

  .toc-title {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-muted);
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }

  .toc-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .toc-item {
    display: flex;
  }

  .toc-item.depth-3 {
    padding-left: 1rem;
  }

  .toc-link {
    font-size: 0.85rem;
    color: var(--text-muted);
    transition: color var(--transition-fast);
    line-height: 1.3;
  }

  .toc-link:hover {
    color: var(--text-heading);
  }

  .toc-link.active {
    color: var(--primary);
    font-weight: 500;
  }
</style>
