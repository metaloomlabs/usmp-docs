---
---

<div id="search-modal" class="fixed inset-0 z-[1000] hidden items-start justify-center bg-black/85 p-4 pt-[12vh]">
  <div class="w-full max-w-[580px] bg-bg-panel border border-neutral-800 rounded-md flex flex-col max-h-[65vh] overflow-hidden animate-[slideDown_0.15s_cubic-bezier(0.16,1,0.3,1)]">
    
    <!-- Top Input panel -->
    <div class="flex items-center gap-3 px-4 border-b border-neutral-900 bg-neutral-950">
      <svg class="text-slate-500 shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
      <input 
        type="text" 
        id="search-input" 
        placeholder="Type keywords to search..." 
        autocomplete="off"
        spellcheck="false"
        class="flex-1 border-none bg-transparent py-4 text-sm text-white placeholder-slate-500 outline-none font-sans"
      />
      <button 
        id="close-search-btn" 
        class="bg-transparent border-none text-slate-500 hover:text-white cursor-pointer p-1 rounded hover:bg-border-subtle transition-colors flex items-center justify-center"
        aria-label="Close search panel"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
      </button>
    </div>
    
    <!-- Results list container -->
    <div id="search-results" class="overflow-y-auto p-2 flex-1 min-h-[120px]">
      <div class="p-8 text-center text-slate-500 text-xs font-mono">
        LAUNCHING SEARCH CORE. AWAITING QUERY PARAMETERS.
      </div>
    </div>
    
    <!-- Control tips footer -->
    <div class="flex items-center gap-6 px-4 py-2.5 bg-slate-950/30 border-t border-border-subtle text-[10px] font-mono text-slate-500">
      <div class="flex items-center gap-1.5"><kbd class="bg-slate-900 border border-slate-800 px-1 py-0.5 rounded">↑↓</kbd> Navigate</div>
      <div class="flex items-center gap-1.5"><kbd class="bg-slate-900 border border-slate-800 px-1 py-0.5 rounded">Enter</kbd> Select</div>
      <div class="flex items-center gap-1.5"><kbd class="bg-slate-900 border border-slate-800 px-1 py-0.5 rounded">ESC</kbd> Close</div>
    </div>
  </div>
</div>

<script>
  interface SearchItem {
    title: string;
    slug: string;
    excerpt: string;
    content: string;
  }

  let searchIndex: SearchItem[] = [];
  let isFetching = false;
  let activeIndex = -1;

  const searchModal = document.getElementById('search-modal');
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchResults = document.getElementById('search-results');
  const closeSearchBtn = document.getElementById('close-search-btn');

  function closeSearch() {
    searchModal?.classList.add('hidden');
    searchModal?.classList.remove('flex');
    if (searchInput) searchInput.value = '';
    activeIndex = -1;
    resetResults();
  }

  function resetResults() {
    if (searchResults) {
      searchResults.innerHTML = `
        <div class="p-8 text-center text-slate-500 text-xs font-mono">
          LAUNCHING SEARCH CORE. AWAITING QUERY PARAMETERS.
        </div>
      `;
    }
  }

  closeSearchBtn?.addEventListener('click', closeSearch);
  searchModal?.addEventListener('click', (e) => {
    if (e.target === searchModal) {
      closeSearch();
    }
  });

  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !searchModal?.classList.contains('hidden')) {
      closeSearch();
    }
  });

  async function fetchSearchIndex() {
    if (searchIndex.length > 0 || isFetching) return;
    isFetching = true;
    try {
      const res = await fetch('/search-index.json');
      searchIndex = await res.json();
    } catch (err) {
      console.error('Failed to load search index', err);
    } finally {
      isFetching = false;
    }
  }

  searchInput?.addEventListener('focus', fetchSearchIndex);
  window.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      fetchSearchIndex();
    }
  });

  searchInput?.addEventListener('input', () => {
    const query = searchInput.value.toLowerCase().trim();
    if (!query) {
      resetResults();
      return;
    }

    if (searchIndex.length === 0) {
      if (searchResults) {
        searchResults.innerHTML = `<div class="p-8 text-center text-slate-500 text-xs font-mono">LOADING SEARCH DATABASE...</div>`;
      }
      return;
    }

    const matches = searchIndex.filter(item => item.content.includes(query));
    renderResults(matches);
  });

  function renderResults(results: SearchItem[]) {
    if (!searchResults) return;
    activeIndex = -1;

    if (results.length === 0) {
      searchResults.innerHTML = `
        <div class="p-8 text-center text-slate-500 text-xs font-mono">
          QUERY RESOLVED WITH 0 MATCHES. TRY OTHER TERMS.
        </div>
      `;
      return;
    }

    searchResults.innerHTML = results.map((item, index) => `
      <a 
        href="${item.slug === '' ? '/docs' : '/docs/' + item.slug}" 
        class="flex flex-col p-3 rounded-lg mb-1 no-underline transition-all duration-200 group search-item-link" 
        data-index="${index}"
      >
        <span class="text-sm font-semibold text-slate-200 group-hover:text-primary transition-colors mb-0.5">${escapeHTML(item.title)}</span>
        <span class="text-xs text-slate-400 leading-normal">${escapeHTML(item.excerpt)}</span>
      </a>
    `).join('');
  }

  function escapeHTML(str: string) {
    return str.replace(/[&<>'"]/g, 
      tag => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[tag] || tag)
    );
  }

  searchInput?.addEventListener('keydown', (e) => {
    const items = searchResults?.querySelectorAll('.search-item-link') || [];
    if (items.length === 0) return;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      activeIndex = (activeIndex + 1) % items.length;
      highlightItem(items);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      activeIndex = (activeIndex - 1 + items.length) % items.length;
      highlightItem(items);
    } else if (e.key === 'Enter') {
      if (activeIndex >= 0 && activeIndex < items.length) {
        e.preventDefault();
        const activeLink = items[activeIndex] as HTMLAnchorElement;
        activeLink.click();
      }
    }
  });

  function highlightItem(items: NodeListOf<Element>) {
    items.forEach((item, index) => {
      if (index === activeIndex) {
        item.classList.add('bg-neutral-900');
        item.classList.add('border-l-2');
        item.classList.add('border-white');
        item.scrollIntoView({ block: 'nearest' });
      } else {
        item.classList.remove('bg-neutral-900');
        item.classList.remove('border-l-2');
        item.classList.remove('border-white');
      }
    });
  }
</script>

<style>
  @keyframes slideDown {
    from {
      transform: translateY(-12px);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }
</style>
