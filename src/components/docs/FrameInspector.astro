---
---

<div class="border border-neutral-900 bg-neutral-950/20 rounded-sm p-6 my-8 text-left select-none font-mono">
  <div class="mb-5 pb-4 border-b border-neutral-900 flex justify-between items-center flex-wrap gap-2">
    <div>
      <h3 class="text-xs font-bold text-white uppercase tracking-wider">Interactive Frame Inspector</h3>
      <p class="text-[11px] text-neutral-400 font-sans mt-1">Hover over frame segments or raw bytes to inspect their wire layout and values.</p>
    </div>
    <div>
      <select 
        id="frame-preset-select" 
        class="bg-neutral-950 border border-white/[0.06] rounded text-[10px] text-slate-300 py-1 px-2 focus:outline-none focus:border-white cursor-pointer transition-colors hover:border-neutral-700 font-mono"
      >
        <option value="pkt_data">DATA FRAME (5 Bytes Payload)</option>
        <option value="pkt_hello">CLIENT_HELLO (38 Bytes Payload)</option>
        <option value="pkt_challenge">SERVER_CHALLENGE (64 Bytes)</option>
        <option value="pkt_error">ERROR FRAME (2 Bytes Payload)</option>
      </select>
    </div>
  </div>

  <!-- FRAME VISUAL SEGMENTS GRID -->
  <div class="flex flex-col gap-2 mb-6">
    <div class="text-[9px] text-neutral-500 font-bold uppercase tracking-wide mb-1">Frame Segment Map</div>
    <div class="flex flex-wrap gap-1.5 text-[9px] font-bold text-center">
      <div class="flex-grow min-w-[50px] border border-purple-500/30 bg-purple-500/5 hover:bg-purple-500/10 text-purple-400 py-2.5 rounded transition-all cursor-help hover:border-purple-400" data-field="magic">
        magic<br/><span class="text-neutral-500 text-[8px] font-normal">2 Bytes</span>
      </div>
      <div class="flex-grow min-w-[40px] border border-cyan-500/30 bg-cyan-500/5 hover:bg-cyan-500/10 text-cyan-400 py-2.5 rounded transition-all cursor-help hover:border-cyan-400" data-field="version">
        version<br/><span class="text-neutral-500 text-[8px] font-normal">1 Byte</span>
      </div>
      <div class="flex-grow min-w-[40px] border border-amber-500/30 bg-amber-500/5 hover:bg-amber-500/10 text-amber-400 py-2.5 rounded transition-all cursor-help hover:border-amber-400" data-field="type">
        type<br/><span class="text-neutral-500 text-[8px] font-normal">1 Byte</span>
      </div>
      <div class="flex-grow min-w-[60px] border border-emerald-500/30 bg-emerald-500/5 hover:bg-emerald-500/10 text-emerald-400 py-2.5 rounded transition-all cursor-help hover:border-emerald-400" data-field="seq">
        seq<br/><span class="text-neutral-500 text-[8px] font-normal">4 Bytes</span>
      </div>
      <div class="flex-grow min-w-[50px] border border-sky-500/30 bg-sky-500/5 hover:bg-sky-500/10 text-sky-400 py-2.5 rounded transition-all cursor-help hover:border-sky-400" data-field="length">
        length<br/><span class="text-neutral-500 text-[8px] font-normal">2 Bytes</span>
      </div>
      <div class="flex-grow min-w-[50px] border border-rose-500/30 bg-rose-500/5 hover:bg-rose-500/10 text-rose-400 py-2.5 rounded transition-all cursor-help hover:border-rose-400" data-field="crc">
        crc<br/><span class="text-neutral-500 text-[8px] font-normal">2 Bytes</span>
      </div>
      <div class="flex-grow-[4] min-w-[120px] border border-neutral-600/30 bg-neutral-600/5 hover:bg-neutral-600/10 text-neutral-400 py-2.5 rounded transition-all cursor-help hover:border-neutral-400" data-field="payload">
        payload (encrypted / auth tag)<br/><span class="text-neutral-500 text-[8px] font-normal" id="segment-payload-size">N Bytes</span>
      </div>
    </div>
  </div>

  <!-- RAW WIRE BYTES VIEW -->
  <div class="bg-neutral-950 border border-neutral-900 rounded-sm p-4 mb-6 relative overflow-hidden">
    <div class="absolute top-2 right-3 text-[7px] text-neutral-600 font-bold uppercase tracking-wider">Raw Hex Payload</div>
    
    <div class="flex flex-wrap gap-x-2 gap-y-1.5 font-mono text-xs md:text-sm pt-1" id="hex-bytes-grid">
      <!-- Generated by script -->
    </div>
  </div>

  <!-- DETAILS DESCRIPTION CARD -->
  <div class="border border-neutral-900 bg-neutral-950/40 rounded-sm p-4 flex flex-col gap-1.5 text-[10px]" id="inspector-details-card">
    <div class="flex justify-between items-center border-b border-neutral-900 pb-2 mb-1">
      <span class="text-white font-bold uppercase tracking-wider text-[11px]" id="detail-title">HOVER ANY FIELD</span>
      <span class="text-neutral-500 font-semibold uppercase tracking-wider" id="detail-meta">Offset: - | Size: -</span>
    </div>
    <div class="flex gap-2 mb-1.5">
      <span class="text-neutral-500">Decoded Hex:</span>
      <span class="text-white font-semibold" id="detail-hex">-</span>
    </div>
    <div class="flex gap-2">
      <span class="text-neutral-500">Parsed Value:</span>
      <span class="text-white font-semibold" id="detail-value">-</span>
    </div>
    <p class="text-neutral-400 font-sans leading-normal mt-2 pt-2 border-t border-white/[0.03]" id="detail-desc">
      Hover over any hex byte or segment block to view decoded fields, endianness details, and specification summaries.
    </p>
  </div>
</div>

<script>
  interface FrameField {
    name: string;
    offset: number;
    size: number;
    hex: string;
    value: string;
    colorClass: string;
    desc: string;
  }

  interface FramePreset {
    magic: FrameField;
    version: FrameField;
    type: FrameField;
    seq: FrameField;
    length: FrameField;
    crc: FrameField;
    payload: FrameField;
    bytes: string[];
  }

  const presets: Record<string, FramePreset> = {
    pkt_data: {
      bytes: ["CD", "AB", "01", "05", "04", "00", "00", "00", "15", "00", "B2", "E4", "8A", "9F", "E4", "03", "A0", "B1", "FF", "CC", "D9", "EE", "87", "A1", "04", "3F", "2B", "5E", "7D", "88", "1A", "0C", "45"],
      magic: {
        name: "Magic bytes",
        offset: 0,
        size: 2,
        hex: "CD AB",
        value: "0xABCD (little-endian)",
        colorClass: "purple",
        desc: "Constant marker to determine frame sync. Little-endian layout makes CD AB translate to 0xABCD. If a node reads invalid magic bytes, it drops connection immediately to save resources."
      },
      version: {
        name: "Version",
        offset: 2,
        size: 1,
        hex: "01",
        value: "1",
        colorClass: "cyan",
        desc: "USMP Protocol revision level. Currently 0x01. If the server is incompatible, it drops connections with a version mismatch error."
      },
      type: {
        name: "Frame type",
        offset: 3,
        size: 1,
        hex: "05",
        value: "0x05 (PKT_DATA)",
        colorClass: "amber",
        desc: "Identifies packet framing mode. Value 0x05 signifies an encrypted data payload carrying sensor readings, alerts, or command exchanges."
      },
      seq: {
        name: "Sequence number",
        offset: 4,
        size: 4,
        hex: "04 00 00 00",
        value: "4 (u32 little-endian)",
        colorClass: "emerald",
        desc: "Monotonically increasing sequence tracker. Prevents replay attacks by ensuring each frame has a unique incremental index. Handshake frames carry 0."
      },
      length: {
        name: "Payload length",
        offset: 8,
        size: 2,
        hex: "15 00",
        value: "21 Bytes (u16 little-endian)",
        colorClass: "sky",
        desc: "Specifies payload sizing. Value 0x0015 represents 21 bytes (5 bytes plaintext encrypted data + 16 bytes GCM authentication tag)."
      },
      crc: {
        name: "Header CRC",
        offset: 10,
        size: 2,
        hex: "B2 E4",
        value: "0xE4B2 (CRC-16/IBM)",
        colorClass: "rose",
        desc: "Cyclic Redundancy Check protecting the integrity of the first 10 header bytes and the payload."
      },
      payload: {
        name: "Encrypted Payload & Tag",
        offset: 12,
        size: 21,
        hex: "8A 9F E4 03 A0 B1 ...",
        value: "Ciphertext + 16-byte GCM Tag",
        colorClass: "neutral",
        desc: "The AES-256-GCM authenticated cipher payload. The final 16 bytes comprise the authentication check tag."
      }
    },
    pkt_hello: {
      bytes: ["CD", "AB", "01", "01", "00", "00", "00", "00", "26", "00", "1F", "9A", "24", "0A", "C4", "3E", "11", "90", "F0", "E1", "B2", "3A", "8F", "C7", "33", "29", "8E", "9A", "BB", "EE", "87", "A1", "04", "3F", "2B", "5E", "7D", "88", "1A", "0C", "45", "D0", "C1", "5E", "8A", "9B", "01", "FF", "CD", "E5"],
      magic: {
        name: "Magic bytes",
        offset: 0,
        size: 2,
        hex: "CD AB",
        value: "0xABCD",
        colorClass: "purple",
        desc: "Constant marker to determine frame sync. Little-endian layout makes CD AB translate to 0xABCD."
      },
      version: {
        name: "Version",
        offset: 2,
        size: 1,
        hex: "01",
        value: "1",
        colorClass: "cyan",
        desc: "USMP Protocol revision level. Currently 0x01."
      },
      type: {
        name: "Frame type",
        offset: 3,
        size: 1,
        hex: "01",
        value: "0x01 (PKT_HELLO)",
        colorClass: "amber",
        desc: "Handshake initial step. Client starts the handshake by advertising its public identities."
      },
      seq: {
        name: "Sequence number",
        offset: 4,
        size: 4,
        hex: "00 00 00 00",
        value: "0 (Handshake constant)",
        colorClass: "emerald",
        desc: "Handshake packets carry sequence 0 as connection is not fully derived yet."
      },
      length: {
        name: "Payload length",
        offset: 8,
        size: 2,
        hex: "26 00",
        value: "38 Bytes (u16 little-endian)",
        colorClass: "sky",
        desc: "Value 0x0026 indicates 38 bytes payload (6 bytes MAC + 32 bytes X25519 public key)."
      },
      crc: {
        name: "Header CRC",
        offset: 10,
        size: 2,
        hex: "1F 9A",
        value: "0x9A1F (CRC-16/IBM)",
        colorClass: "rose",
        desc: "Cyclic Redundancy Check protecting the integrity of the handshake hello packet."
      },
      payload: {
        name: "Device ID & X25519 Public Key",
        offset: 12,
        size: 38,
        hex: "24 0A C4 3E 11 90 ...",
        value: "MAC: 24:0a:c4:3e:11:90 || Key: pub_C",
        colorClass: "neutral",
        desc: "Carries 6 bytes Client Mac address, concatenated with 32 bytes ephemeral public X25519 curve key to execute Diffie-Hellman."
      }
    },
    pkt_challenge: {
      bytes: ["CD", "AB", "01", "02", "00", "00", "00", "00", "40", "00", "D9", "A1", "88", "1A", "0C", "45", "D0", "C1", "5E", "8A", "9B", "01", "FF", "CD", "E5", "A1", "30", "1F", "E4", "B9", "CC", "D4", "2E", "1F", "9A", "24", "0A", "C4", "3E", "11", "90", "F0", "E1", "B2", "3A", "8F", "C7", "33", "29", "8E", "9A", "BB", "EE", "87", "A1", "04", "3F", "2B", "5E", "7D", "88", "1A", "0C", "45", "9A", "BC", "1F", "B0", "45", "66", "11", "FF", "00", "AA", "3B", "EE"],
      magic: {
        name: "Magic bytes",
        offset: 0,
        size: 2,
        hex: "CD AB",
        value: "0xABCD",
        colorClass: "purple",
        desc: "Constant marker to determine frame sync. Little-endian layout makes CD AB translate to 0xABCD."
      },
      version: {
        name: "Version",
        offset: 2,
        size: 1,
        hex: "01",
        value: "1",
        colorClass: "cyan",
        desc: "USMP Protocol revision level. Currently 0x01."
      },
      type: {
        name: "Frame type",
        offset: 3,
        size: 1,
        hex: "02",
        value: "0x02 (PKT_CHALLENGE)",
        colorClass: "amber",
        desc: "Handshake second step. The server answers with an authentication nonce and its own public key."
      },
      seq: {
        name: "Sequence number",
        offset: 4,
        size: 4,
        hex: "00 00 00 00",
        value: "0 (Handshake constant)",
        colorClass: "emerald",
        desc: "Handshake packets carry sequence 0 as connection is not fully derived yet."
      },
      length: {
        name: "Payload length",
        offset: 8,
        size: 2,
        hex: "40 00",
        value: "64 Bytes (u16 little-endian)",
        colorClass: "sky",
        desc: "Value 0x0040 indicates 64 bytes payload (32 bytes challenge nonce + 32 bytes X25519 public key)."
      },
      crc: {
        name: "Header CRC",
        offset: 10,
        size: 2,
        hex: "D9 A1",
        value: "0xA1D9 (CRC-16/IBM)",
        colorClass: "rose",
        desc: "Cyclic Redundancy Check protecting the integrity of the challenge packet."
      },
      payload: {
        name: "Nonce & Server Ephemeral Key",
        offset: 12,
        size: 64,
        hex: "88 1A 0C 45 D0 C1 ...",
        value: "Nonce (32B) || Server Ephemeral Key (32B)",
        colorClass: "neutral",
        desc: "Contains a cryptographically secure 32-byte challenge nonce, followed by the server's 32-byte X25519 key (pub_S)."
      }
    },
    pkt_error: {
      bytes: ["CD", "AB", "01", "08", "02", "00", "00", "00", "02", "00", "F1", "C2", "00", "03"],
      magic: {
        name: "Magic bytes",
        offset: 0,
        size: 2,
        hex: "CD AB",
        value: "0xABCD",
        colorClass: "purple",
        desc: "Constant marker to determine frame sync. Little-endian layout CD AB translates to 0xABCD."
      },
      version: {
        name: "Version",
        offset: 2,
        size: 1,
        hex: "01",
        value: "1",
        colorClass: "cyan",
        desc: "USMP Protocol revision level. Currently 0x01."
      },
      type: {
        name: "Frame type",
        offset: 3,
        size: 1,
        hex: "08",
        value: "0x08 (PKT_ERROR)",
        colorClass: "amber",
        desc: "Error reporting frame. Used to signal protocol violations or authentication errors."
      },
      seq: {
        name: "Sequence number",
        offset: 4,
        size: 4,
        hex: "02 00 00 00",
        value: "2",
        colorClass: "emerald",
        desc: "Sequence index at which the protocol error occurred."
      },
      length: {
        name: "Payload length",
        offset: 8,
        size: 2,
        hex: "02 00",
        value: "2 Bytes (u16 little-endian)",
        colorClass: "sky",
        desc: "Sizing. Value 0x0002 indicates 2 bytes of error description codes."
      },
      crc: {
        name: "Header CRC",
        offset: 10,
        size: 2,
        hex: "F1 C2",
        value: "0xC2F1 (CRC-16/IBM)",
        colorClass: "rose",
        desc: "Cyclic Redundancy Check safeguarding error frame contents."
      },
      payload: {
        name: "Error Category & Code",
        offset: 12,
        size: 2,
        hex: "00 03",
        value: "Category: 0x00 || Error Code: 0x03 (ERR_AUTH_FAILED)",
        colorClass: "neutral",
        desc: "Provides details about what went wrong. The sequence 00 03 signifies an authentication check failure (e.g. wrong Pre-Shared Key)."
      }
    }
  };

  let currentPreset = 'pkt_data';

  // Elements
  const selectPreset = document.getElementById('frame-preset-select') as HTMLSelectElement;
  const gridEl = document.getElementById('hex-bytes-grid');
  const detailsCard = document.getElementById('inspector-details-card');
  const payloadSizeEl = document.getElementById('segment-payload-size');

  const titleEl = document.getElementById('detail-title');
  const metaEl = document.getElementById('detail-meta');
  const hexEl = document.getElementById('detail-hex');
  const valEl = document.getElementById('detail-value');
  const descEl = document.getElementById('detail-desc');

  // Colors
  const borderColors: Record<string, string> = {
    purple: 'border-purple-500/50 text-purple-400 bg-purple-950/20',
    cyan: 'border-cyan-500/50 text-cyan-400 bg-cyan-950/20',
    amber: 'border-amber-500/50 text-amber-400 bg-amber-950/20',
    emerald: 'border-emerald-500/50 text-emerald-400 bg-emerald-950/20',
    sky: 'border-sky-500/50 text-sky-400 bg-sky-950/20',
    rose: 'border-rose-500/50 text-rose-400 bg-rose-950/20',
    neutral: 'border-neutral-500/40 text-neutral-300 bg-neutral-900/30'
  };

  const textColors: Record<string, string> = {
    purple: 'text-purple-400',
    cyan: 'text-cyan-400',
    amber: 'text-amber-400',
    emerald: 'text-emerald-400',
    sky: 'text-sky-400',
    rose: 'text-rose-400',
    neutral: 'text-neutral-400'
  };

  // Helper to determine field by byte offset
  function getFieldByOffset(offset: number): keyof Omit<FramePreset, 'bytes'> {
    if (offset < 2) return 'magic';
    if (offset === 2) return 'version';
    if (offset === 3) return 'type';
    if (offset < 8) return 'seq';
    if (offset < 10) return 'length';
    if (offset < 12) return 'crc';
    return 'payload';
  }

  // Draw hex grid
  function renderHexGrid() {
    if (!gridEl) return;
    gridEl.innerHTML = '';
    const preset = presets[currentPreset];
    
    if (payloadSizeEl) {
      payloadSizeEl.innerText = `${preset.payload.size} Bytes`;
    }

    preset.bytes.forEach((b, idx) => {
      const fieldName = getFieldByOffset(idx);
      const fieldInfo = preset[fieldName];
      const byteBox = document.createElement('span');
      
      byteBox.innerText = b;
      byteBox.className = `px-2 py-1 border rounded text-[11px] font-bold cursor-help transition-all duration-150 border-white/[0.04] bg-neutral-950 text-neutral-600 hover:scale-105`;
      byteBox.setAttribute('data-offset', idx.toString());
      byteBox.setAttribute('data-field', fieldName);
      
      // Events
      byteBox.addEventListener('mouseenter', () => highlightField(fieldName));
      byteBox.addEventListener('mouseleave', clearHighlight);
      
      gridEl.appendChild(byteBox);
    });
  }

  function highlightField(fieldName: keyof Omit<FramePreset, 'bytes'>) {
    const preset = presets[currentPreset];
    const info = preset[fieldName];
    if (!info) return;

    // Highlight segments
    document.querySelectorAll('[data-field]').forEach(el => {
      const f = el.getAttribute('data-field');
      if (f === fieldName) {
        el.className = el.className.replace(/border-[a-z]+-500\/30/g, '').replace(/bg-[a-z]+-500\/5/g, '');
        el.classList.add('border-white', 'bg-white/10', 'scale-[1.02]');
      } else {
        el.classList.add('opacity-40');
      }
    });

    // Highlight hex bytes
    document.querySelectorAll('[data-offset]').forEach(el => {
      const f = el.getAttribute('data-field');
      if (f === fieldName) {
        el.className = `px-2 py-1 border rounded text-[11px] font-bold cursor-help transition-all duration-150 ${borderColors[info.colorClass]} scale-105 z-10`;
      } else {
        el.classList.add('opacity-30');
      }
    });

    // Set details card
    if (titleEl && metaEl && hexEl && valEl && descEl && detailsCard) {
      titleEl.innerText = info.name;
      titleEl.className = `font-bold uppercase tracking-wider text-[11px] ${textColors[info.colorClass]}`;
      metaEl.innerText = `Offset: ${info.offset} | Size: ${info.size} Byte${info.size > 1 ? 's' : ''}`;
      hexEl.innerText = info.hex;
      valEl.innerText = info.value;
      descEl.innerText = info.desc;
      
      detailsCard.className = `border rounded-sm p-4 flex flex-col gap-1.5 text-[10px] bg-neutral-950/40 transition-colors duration-200 border-${info.colorClass}-500/20`;
    }
  }

  function clearHighlight() {
    // Reset segments
    document.querySelectorAll('[data-field]').forEach(el => {
      const f = el.getAttribute('data-field') as keyof Omit<FramePreset, 'bytes'>;
      el.className = el.className.replace('border-white', '').replace('bg-white/10', '').replace('scale-[1.02]', '').replace('opacity-40', '');
    });

    // Reset hex bytes
    document.querySelectorAll('[data-offset]').forEach(el => {
      el.className = `px-2 py-1 border rounded text-[11px] font-bold cursor-help transition-all duration-150 border-white/[0.04] bg-neutral-950 text-neutral-600 hover:scale-105`;
    });

    // Reset details card (keep info but remove active borders)
    if (detailsCard) {
      detailsCard.className = 'border border-neutral-900 bg-neutral-950/40 rounded-sm p-4 flex flex-col gap-1.5 text-[10px]';
    }
  }

  // Preset select event
  if (selectPreset) {
    selectPreset.addEventListener('change', () => {
      currentPreset = selectPreset.value;
      renderHexGrid();
      clearHighlight();
    });
  }

  // Bind segment buttons
  document.querySelectorAll('[data-field]').forEach(el => {
    const fieldName = el.getAttribute('data-field') as keyof Omit<FramePreset, 'bytes'>;
    el.addEventListener('mouseenter', () => highlightField(fieldName));
    el.addEventListener('mouseleave', clearHighlight);
  });

  // Initial draw
  renderHexGrid();
</script>
