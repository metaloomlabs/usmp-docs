---
interface Props {
  type?: 'simple' | 'detailed';
}

const { type = 'simple' } = Astro.props;
---

<div class="border border-neutral-900 bg-neutral-950/20 rounded-sm p-6 my-8 text-left select-none font-mono">
  <div class="mb-5 pb-4 border-b border-neutral-900 flex justify-between items-center">
    <div>
      <h3 class="text-xs font-bold text-white uppercase tracking-wider">Handshake Sequence Flow</h3>
      <p class="text-[11px] text-neutral-400 font-sans mt-1">Interactive step-by-step transaction flow. Hover over steps to inspect data payloads.</p>
    </div>
    <span class="text-[9px] font-bold text-neutral-500 uppercase tracking-wider">Interactive Vector Diagram</span>
  </div>

  <div class="flex justify-center items-center py-4 bg-neutral-950/60 border border-neutral-900 rounded-sm relative overflow-hidden">
    <div class="absolute inset-0 grid-bg-overlay opacity-10"></div>

    {type === 'simple' ? (
      /* SIMPLE TIMELINE (Homepage/Intro) */
      <svg class="w-full max-w-[480px] h-[320px] select-none text-[9px]" viewBox="0 0 400 320" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <marker id="seq-arrow-right" viewBox="0 0 10 10" refX="6" refY="5" markerWidth="6" markerHeight="6" orient="auto">
            <path d="M 0 1 L 10 5 L 0 9 z" fill="#555555" />
          </marker>
          <marker id="seq-arrow-left" viewBox="0 0 10 10" refX="4" refY="5" markerWidth="6" markerHeight="6" orient="auto">
            <path d="M 10 1 L 0 5 L 10 9 z" fill="#555555" />
          </marker>
          <marker id="seq-arrow-right-active" viewBox="0 0 10 10" refX="6" refY="5" markerWidth="6" markerHeight="6" orient="auto">
            <path d="M 0 1 L 10 5 L 0 9 z" fill="#ffffff" />
          </marker>
          <marker id="seq-arrow-left-active" viewBox="0 0 10 10" refX="4" refY="5" markerWidth="6" markerHeight="6" orient="auto">
            <path d="M 10 1 L 0 5 L 10 9 z" fill="#ffffff" />
          </marker>
        </defs>

        <!-- Vertical lanes -->
        <line x1="80" y1="40" x2="80" y2="280" stroke="#222222" stroke-width="1.5" stroke-dasharray="3 3" />
        <line x1="320" y1="40" x2="320" y2="280" stroke="#222222" stroke-width="1.5" stroke-dasharray="3 3" />

        <!-- Lane Labels -->
        <rect x="30" y="10" width="100" height="24" rx="2" fill="#0d0d0d" stroke="#555555" stroke-width="1" />
        <text x="80" y="24" text-anchor="middle" fill="#ffffff" font-weight="bold">ESP32 (Client)</text>

        <rect x="270" y="10" width="100" height="24" rx="2" fill="#0d0d0d" stroke="#555555" stroke-width="1" />
        <text x="320" y="24" text-anchor="middle" fill="#ffffff" font-weight="bold">Gateway (Server)</text>

        <!-- STEP 1: CLIENT_HELLO -->
        <g class="seq-step-group cursor-pointer" data-step="1">
          <line x1="80" y1="70" x2="320" y2="70" stroke="#444444" stroke-width="1.5" marker-end="url(#seq-arrow-right)" class="transition-all duration-200" />
          <text x="200" y="63" text-anchor="middle" fill="#888888" class="font-bold transition-colors">1. CLIENT_HELLO</text>
          <text x="200" y="82" text-anchor="middle" fill="#555555" class="text-[7.5px]">"Hello. I am ESP32 node."</text>
        </g>

        <!-- STEP 2: SERVER_CHALLENGE -->
        <g class="seq-step-group cursor-pointer" data-step="2">
          <line x1="320" y1="120" x2="80" y2="120" stroke="#444444" stroke-width="1.5" marker-end="url(#seq-arrow-left)" class="transition-all duration-200" />
          <text x="200" y="113" text-anchor="middle" fill="#888888" class="font-bold transition-colors">2. SERVER_CHALLENGE</text>
          <text x="200" y="132" text-anchor="middle" fill="#555555" class="text-[7.5px]">"Prove identity. Here is a challenge nonce."</text>
        </g>

        <!-- STEP 3: HELLO_ACK -->
        <g class="seq-step-group cursor-pointer" data-step="3">
          <line x1="80" y1="170" x2="320" y2="170" stroke="#444444" stroke-width="1.5" marker-end="url(#seq-arrow-right)" class="transition-all duration-200" />
          <text x="200" y="163" text-anchor="middle" fill="#888888" class="font-bold transition-colors">3. CLIENT_HELLO_ACK</text>
          <text x="200" y="182" text-anchor="middle" fill="#555555" class="text-[7.5px]">"Signed challenge proof using PSK."</text>
        </g>

        <!-- STEP 4: SESSION_OK -->
        <g class="seq-step-group cursor-pointer" data-step="4">
          <line x1="320" y1="220" x2="80" y2="220" stroke="#444444" stroke-width="1.5" marker-end="url(#seq-arrow-left)" class="transition-all duration-200" />
          <text x="200" y="213" text-anchor="middle" fill="#888888" class="font-bold transition-colors">4. SERVER_SESSION_OK</text>
          <text x="200" y="232" text-anchor="middle" fill="#555555" class="text-[7.5px]">"Proof OK. Session established."</text>
        </g>

        <!-- Channel Established Bracket -->
        <g class="seq-step-group" data-step="5">
          <rect x="60" y="258" width="280" height="24" rx="2" fill="rgba(52, 211, 153, 0.03)" stroke="#10b981" stroke-width="1" stroke-dasharray="3 3" />
          <text x="200" y="273" text-anchor="middle" fill="#10b981" font-weight="bold" class="tracking-wide">SECURE AES-256-GCM SESSION CHANNEL</text>
        </g>
      </svg>
    ) : (
      /* DETAILED TIMELINE (Handshake Specification Page) */
      <svg class="w-full max-w-[500px] h-[400px] select-none text-[8.5px]" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <marker id="seq-arrow-right" viewBox="0 0 10 10" refX="6" refY="5" markerWidth="6" markerHeight="6" orient="auto">
            <path d="M 0 1 L 10 5 L 0 9 z" fill="#555555" />
          </marker>
          <marker id="seq-arrow-left" viewBox="0 0 10 10" refX="4" refY="5" markerWidth="6" markerHeight="6" orient="auto">
            <path d="M 10 1 L 0 5 L 10 9 z" fill="#555555" />
          </marker>
          <marker id="seq-arrow-right-active" viewBox="0 0 10 10" refX="6" refY="5" markerWidth="6" markerHeight="6" orient="auto">
            <path d="M 0 1 L 10 5 L 0 9 z" fill="#ffffff" />
          </marker>
          <marker id="seq-arrow-left-active" viewBox="0 0 10 10" refX="4" refY="5" markerWidth="6" markerHeight="6" orient="auto">
            <path d="M 10 1 L 0 5 L 10 9 z" fill="#ffffff" />
          </marker>
        </defs>

        <!-- Vertical lanes -->
        <line x1="80" y1="40" x2="80" y2="360" stroke="#222222" stroke-width="1.5" stroke-dasharray="3 3" />
        <line x1="320" y1="40" x2="320" y2="360" stroke="#222222" stroke-width="1.5" stroke-dasharray="3 3" />

        <!-- Lane Labels -->
        <rect x="30" y="10" width="100" height="24" rx="2" fill="#0d0d0d" stroke="#555555" stroke-width="1" />
        <text x="80" y="24" text-anchor="middle" fill="#ffffff" font-weight="bold">Client (ESP32)</text>

        <rect x="270" y="10" width="100" height="24" rx="2" fill="#0d0d0d" stroke="#555555" stroke-width="1" />
        <text x="320" y="24" text-anchor="middle" fill="#ffffff" font-weight="bold">Server (Gateway)</text>

        <!-- STEP 1: PKT_HELLO -->
        <g class="seq-step-group cursor-pointer" data-step="d1">
          <line x1="80" y1="75" x2="320" y2="75" stroke="#444444" stroke-width="1.5" marker-end="url(#seq-arrow-right)" class="transition-all duration-200" />
          <text x="200" y="65" text-anchor="middle" fill="#888888" class="font-bold transition-colors">1. PKT_HELLO (0x01)</text>
          <text x="200" y="85" text-anchor="middle" fill="#cccccc" class="font-bold text-[7.5px] bg-neutral-900 py-0.5 px-1 rounded select-all">device_id (6B) || pub_C (32B)</text>
        </g>

        <!-- STEP 2: PKT_CHALLENGE -->
        <g class="seq-step-group cursor-pointer" data-step="d2">
          <line x1="320" y1="135" x2="80" y2="135" stroke="#444444" stroke-width="1.5" marker-end="url(#seq-arrow-left)" class="transition-all duration-200" />
          <text x="200" y="125" text-anchor="middle" fill="#888888" class="font-bold transition-colors">2. PKT_CHALLENGE (0x02)</text>
          <text x="200" y="145" text-anchor="middle" fill="#cccccc" class="font-bold text-[7.5px] bg-neutral-900 py-0.5 px-1 rounded select-all">nonce (32B) || pub_S (32B)</text>
        </g>

        <!-- DERIVATION BOX -->
        <g class="seq-step-group" data-step="d-derive">
          <rect x="50" y="170" width="300" height="36" rx="2" fill="#0d0d0d" stroke="#222222" stroke-width="1" />
          <text x="200" y="183" text-anchor="middle" fill="#888888" font-size="7.5" font-weight="bold">ECDH KEY DERIVATION (INDEPENDENT)</text>
          <text x="200" y="197" text-anchor="middle" fill="#555555" font-size="7">shared = X25519(priv, pub_peer) -> HKDF-SHA256(shared, nonce)</text>
        </g>

        <!-- STEP 3: PKT_HELLO_ACK -->
        <g class="seq-step-group cursor-pointer" data-step="d3">
          <line x1="80" y1="245" x2="320" y2="245" stroke="#444444" stroke-width="1.5" marker-end="url(#seq-arrow-right)" class="transition-all duration-200" />
          <text x="200" y="235" text-anchor="middle" fill="#888888" class="font-bold transition-colors">3. PKT_HELLO_ACK (0x03)</text>
          <text x="200" y="255" text-anchor="middle" fill="#cccccc" class="font-bold text-[7.5px] bg-neutral-900 py-0.5 px-1 rounded select-all">hmac_client (32B) = HMAC-SHA256(PSK, nonce||device_id)</text>
        </g>

        <!-- STEP 4: PKT_SESSION_OK -->
        <g class="seq-step-group cursor-pointer" data-step="d4">
          <line x1="320" y1="305" x2="80" y2="305" stroke="#444444" stroke-width="1.5" marker-end="url(#seq-arrow-left)" class="transition-all duration-200" />
          <text x="200" y="295" text-anchor="middle" fill="#888888" class="font-bold transition-colors">4. PKT_SESSION_OK (0x04)</text>
          <text x="200" y="315" text-anchor="middle" fill="#cccccc" class="font-bold text-[7.5px] bg-neutral-900 py-0.5 px-1 rounded select-all">session_id (4B) || hmac_server (32B)</text>
        </g>

        <!-- Active Bracket -->
        <g class="seq-step-group" data-step="d5">
          <rect x="60" y="340" width="280" height="24" rx="2" fill="rgba(52, 211, 153, 0.03)" stroke="#10b981" stroke-width="1" stroke-dasharray="3 3" />
          <text x="200" y="355" text-anchor="middle" fill="#10b981" font-weight="bold" class="tracking-wide">SESSION ESTABLISHED & MUTUALLY AUTHENTICATED</text>
        </g>
      </svg>
    )}
  </div>

  <!-- HOVER EXPLANATION PANEL -->
  <div class="border border-neutral-900 bg-neutral-950/40 rounded-sm p-4 text-[10px] min-h-[72px]" id="seq-explanation-card">
    <div class="text-white font-bold uppercase tracking-wider mb-1" id="seq-expl-title">Hover Handshake Steps</div>
    <p class="text-neutral-400 font-sans leading-normal" id="seq-expl-desc">
      Hover over any handshake transaction step above to inspect specific byte sizes, payloads, authentication mathematical proofs, and security context.
    </p>
  </div>
</div>

<script>
  interface StepExplanation {
    title: string;
    desc: string;
  }

  const explanations: Record<string, StepExplanation> = {
    '1': {
      title: "Step 1: Client Hello",
      desc: "The client ESP32 initializes the session by broadcasting its 6-byte MAC address and a 32-byte X25519 ephemeral public key. No encryption is possible yet; this announces the connection intent."
    },
    '2': {
      title: "Step 2: Server Challenge",
      desc: "The gateway gateway responds with a freshly generated 32-byte secure random challenge nonce and its own 32-byte X25519 public key. This nonce guarantees freshness and secures against replay attacks."
    },
    '3': {
      title: "Step 3: Client Hello Ack",
      desc: "The client calculates an HMAC proof proving it knows the Pre-Shared Key (PSK). It hashes the server's challenge nonce and its own MAC address. The server verifies this to authenticate the client device."
    },
    '4': {
      title: "Step 4: Server Session OK",
      desc: "The server returns a newly generated 4-byte session identifier and its own HMAC signature verification of the nonce and session ID. The client verifies it to authenticate the gateway server, completing mutual verification."
    },
    'd1': {
      title: "PKT_HELLO (Type 0x01)",
      desc: "Carries client device MAC address (6 bytes) and ephemeral X25519 curve public key (32 bytes). Size: 38 bytes payload + 12 bytes header."
    },
    'd2': {
      title: "PKT_CHALLENGE (Type 0x02)",
      desc: "Carries 32 bytes challenge nonce and 32 bytes server ephemeral key (pub_S). Size: 64 bytes payload + 12 bytes header."
    },
    'd3': {
      title: "PKT_HELLO_ACK (Type 0x03)",
      desc: "Client transmits its HMAC-SHA256 signature proof of ownership of the PSK. Prevents rogue hardware connections. Size: 32 bytes payload."
    },
    'd4': {
      title: "PKT_SESSION_OK (Type 0x04)",
      desc: "Server registers the session, issues a 4-byte session ID, and authenticates itself via HMAC-SHA256. Size: 36 bytes payload."
    }
  };

  const stepGroups = document.querySelectorAll('.seq-step-group');
  const explTitle = document.getElementById('seq-expl-title');
  const explDesc = document.getElementById('seq-expl-desc');
  const explCard = document.getElementById('seq-explanation-card');

  stepGroups.forEach(group => {
    const step = group.getAttribute('data-step');
    if (!step || !explanations[step]) return;

    group.addEventListener('mouseenter', () => {
      // Highlight arrow and texts
      const line = group.querySelector('line');
      const text = group.querySelector('text');
      
      if (line) {
        line.setAttribute('stroke', '#ffffff');
        line.setAttribute('stroke-width', '2');
        const marker = line.getAttribute('marker-end');
        if (marker === 'url(#seq-arrow-right)') line.setAttribute('marker-end', 'url(#seq-arrow-right-active)');
        if (marker === 'url(#seq-arrow-left)') line.setAttribute('marker-end', 'url(#seq-arrow-left-active)');
      }
      
      if (text) {
        text.setAttribute('fill', '#ffffff');
      }

      // Dim other steps
      stepGroups.forEach(other => {
        if (other !== group && other.getAttribute('data-step') !== '5' && other.getAttribute('data-step') !== 'd5') {
          other.classList.add('opacity-30');
        }
      });

      // Show explanation
      const info = explanations[step];
      if (explTitle && explDesc && explCard) {
        explTitle.innerText = info.title;
        explDesc.innerText = info.desc;
        explCard.className = 'border border-white/20 bg-neutral-950/40 rounded-sm p-4 text-[10px] min-h-[72px] transition-colors duration-200';
      }
    });

    group.addEventListener('mouseleave', () => {
      // Restore styles
      const line = group.querySelector('line');
      const text = group.querySelector('text');
      
      if (line) {
        line.setAttribute('stroke', '#444444');
        line.setAttribute('stroke-width', '1.5');
        const marker = line.getAttribute('marker-end');
        if (marker === 'url(#seq-arrow-right-active)') line.setAttribute('marker-end', 'url(#seq-arrow-right)');
        if (marker === 'url(#seq-arrow-left-active)') line.setAttribute('marker-end', 'url(#seq-arrow-left)');
      }
      
      if (text) {
        text.setAttribute('fill', '#888888');
      }

      // Restore other steps opacity
      stepGroups.forEach(other => {
        other.classList.remove('opacity-30');
      });

      // Reset explanation card styling (keep text for layout transitions)
      if (explCard) {
        explCard.className = 'border border-neutral-900 bg-neutral-950/40 rounded-sm p-4 text-[10px] min-h-[72px]';
      }
    });
  });
</script>
