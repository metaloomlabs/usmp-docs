---
interface Props {
  method: string;
  path: string;
  desc: string;
}

const { method, path, desc } = Astro.props;

// Determine badge color
const isGet = method.toUpperCase() === 'GET' || method.toUpperCase() === 'C → S';
const isPost = method.toUpperCase() === 'POST' || method.toUpperCase() === 'S → C';
const badgeClass = isGet 
  ? 'bg-neutral-900 text-white border-neutral-700' 
  : isPost 
    ? 'bg-neutral-950 text-neutral-300 border-neutral-800' 
    : 'bg-neutral-950 text-neutral-400 border-neutral-800/60';
---

<div class="border border-border-subtle bg-bg-card rounded-card overflow-hidden my-6 box-shadow shadow-md">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 p-4 bg-neutral-900/40 border-b border-border-subtle">
    <div class="flex items-center gap-3">
      <span class={`px-2.5 py-1 text-xs font-mono font-semibold uppercase tracking-wider border rounded-md ${badgeClass}`}>
        {method}
      </span>
      <span class="font-mono text-sm font-semibold text-white tracking-wide">{path}</span>
    </div>
    <span class="text-xs text-slate-400 font-medium font-sans">PROTOCOL ENDPOINT</span>
  </div>
  <div class="p-4 text-sm text-slate-300">
    <p class="mb-3 leading-relaxed">{desc}</p>
    <slot />
  </div>
</div>
