---
---

<div class="telemetry-panel-container shrink-0 flex flex-col gap-4 font-mono text-[10px]">
  
  <!-- Panel Title -->
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-1.5">
      <span class="telemetry-status-dot w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
      <span class="font-bold tracking-wider text-text-heading uppercase text-[9px]">PROTOCOL ANALYZER</span>
    </div>
    <span class="telemetry-status-label text-text-primary/60 font-medium text-[8px]">ACTIVE (SECURED)</span>
  </div>

  <!-- Connection Visualization -->
  <div class="bg-bg-code/50 border border-border-subtle rounded-lg p-2.5 flex flex-col gap-1.5 relative overflow-hidden">
    <div class="flex items-center justify-between text-[7px] text-text-primary/60 font-bold uppercase tracking-wide">
      <span>Client Device</span>
      <span>Secure Link</span>
      <span>Gateway Server</span>
    </div>
    <div class="flex items-center justify-between gap-1 font-mono text-[9px] mt-0.5">
      <span class="visual-client-node text-text-heading font-bold bg-bg-panel border border-border-subtle px-2 py-0.5 rounded text-[8px]">ESP32</span>
      
      <!-- Flow animation -->
      <div class="visual-link-path flex-grow flex items-center justify-center gap-1 text-text-primary/40 font-bold tracking-widest text-[8px]">
        <span class="text-emerald-400/80 animate-pulse">─</span>
        <span class="telemetry-flow-indicator text-[8px] font-semibold text-emerald-500 bg-emerald-500/10 border border-emerald-500/20 px-1 rounded select-none uppercase">SECURED</span>
        <span class="text-emerald-400/80 animate-pulse">─></span>
      </div>
      
      <span class="text-text-heading font-bold bg-bg-panel border border-border-subtle px-2 py-0.5 rounded text-[8px]">PYTHON</span>
    </div>
  </div>

  <!-- Key Info Grid -->
  <div class="bg-bg-panel border border-border-subtle rounded-lg p-2.5 flex flex-col gap-1.5">
    <div class="flex justify-between items-center">
      <span class="text-text-primary/60 flex items-center gap-1">
        CIPHER:
        <span class="group relative inline-block cursor-help text-text-primary/40">[?]
          <span class="absolute bottom-4 left-0 hidden group-hover:block bg-bg-panel text-text-primary text-[8px] p-2 rounded border border-border-subtle w-[140px] z-20 font-sans leading-normal normal-case shadow-lg">AES-256-GCM symmetric encryption secures all payloads.</span>
        </span>
      </span>
      <span class="text-text-heading font-semibold">AES_256_GCM</span>
    </div>
    <div class="flex justify-between items-center">
      <span class="text-text-primary/60 flex items-center gap-1">
        KEY_EXCH:
        <span class="group relative inline-block cursor-help text-text-primary/40">[?]
          <span class="absolute bottom-4 left-0 hidden group-hover:block bg-bg-panel text-text-primary text-[8px] p-2 rounded border border-border-subtle w-[140px] z-20 font-sans leading-normal normal-case shadow-lg">Diffie-Hellman Key Exchange using X25519 elliptic curve.</span>
        </span>
      </span>
      <span class="text-text-heading">ECDH_X25519</span>
    </div>
    <div class="flex justify-between items-center">
      <span class="text-text-primary/60 flex items-center gap-1">
        INTERFACE:
      </span>
      <select 
        class="telemetry-transport-select bg-bg-code border border-border-subtle rounded text-[8px] text-text-primary py-0.5 px-1 focus:outline-none focus:border-brand-accent cursor-pointer transition-colors hover:border-border-glow"
        aria-label="Transport interface select"
      >
        <option value="tcp">TCP/IP Socket</option>
        <option value="uart">UART (Serial)</option>
        <option value="udp">UDP Socket</option>
      </select>
    </div>
  </div>

  <!-- Counters -->
  <div class="grid grid-cols-2 gap-2 text-[9px]">
    <div class="border border-border-subtle bg-bg-panel p-2 rounded-lg flex flex-col relative group">
      <span class="text-text-primary/60 uppercase text-[8px] flex justify-between">
        TX_FRAMES
        <span class="cursor-help text-text-primary/40">[?]</span>
      </span>
      <span class="vis-tx-counter text-text-heading font-bold text-[11px] tracking-wider mt-0.5">001,482</span>
      <!-- tooltip -->
      <span class="absolute bottom-full left-0 mb-1 hidden group-hover:block bg-bg-panel text-text-primary text-[8px] p-2 rounded border border-border-subtle w-[110px] z-20 font-sans leading-normal font-normal shadow-lg">Packets sent from client to gateway.</span>
    </div>
    <div class="border border-border-subtle bg-bg-panel p-2 rounded-lg flex flex-col relative group">
      <span class="text-text-primary/60 uppercase text-[8px] flex justify-between">
        RX_FRAMES
        <span class="cursor-help text-text-primary/40">[?]</span>
      </span>
      <span class="vis-rx-counter text-text-heading font-bold text-[11px] tracking-wider mt-0.5">001,479</span>
      <!-- tooltip -->
      <span class="absolute bottom-full right-0 mb-1 hidden group-hover:block bg-bg-panel text-text-primary text-[8px] p-2 rounded border border-border-subtle w-[110px] z-20 font-sans leading-normal font-normal shadow-lg">Packets received by client from gateway.</span>
    </div>
  </div>

  <!-- Log Box Header Tabs -->
  <div class="flex flex-col gap-1.5">
    <div class="flex items-center justify-between">
      <span class="text-text-primary/60 uppercase tracking-wide text-[8px] font-bold">Transaction Logs</span>
      <div class="flex border border-border-subtle rounded bg-bg-code p-0.5">
        <button 
          class="log-tab-decoded px-1.5 py-0.5 rounded-[2px] text-[7px] font-bold tracking-wider cursor-pointer border-none text-text-heading bg-bg-panel transition-colors"
        >
          DECODED
        </button>
        <button 
          class="log-tab-raw px-1.5 py-0.5 rounded-[2px] text-[7px] font-bold tracking-wider cursor-pointer border-none text-text-primary/65 hover:text-text-heading transition-colors bg-transparent"
        >
          RAW HEX
        </button>
      </div>
    </div>
    
    <!-- Logger Screen -->
    <div 
      class="telemetry-hex-logger h-[105px] bg-bg-code border border-border-subtle rounded-lg p-2 overflow-y-auto font-mono text-[8px] text-text-primary/70 flex flex-col gap-1 leading-normal"
    >
      <div class="text-text-primary/50">[SYS] Ready. Click Restart simulation to watch handshake...</div>
    </div>
  </div>

  <!-- Trigger Button -->
  <button 
    class="btn-simulate-reset w-full bg-text-heading text-bg-panel hover:opacity-90 transition-opacity border-none py-1.5 rounded text-[9px] font-bold cursor-pointer uppercase tracking-wider font-mono flex items-center justify-center gap-1.5 shadow"
  >
    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/></svg>
    Restart Handshake
  </button>
</div>

<script>
  interface LogEntry {
    type: 'tx' | 'rx' | 'sec' | 'sys' | 'conn';
    decoded: string;
    rawHex: string;
    timestamp: string;
  }

  function initTelemetry(container: HTMLElement) {
    let txCount = 1482;
    let rxCount = 1479;
    let currentLogMode = 'decoded'; // 'decoded' or 'raw'
    let isSimulating = false;

    // Keep a buffer of active log entries
    const logsBuffer: LogEntry[] = [
      { type: 'sys', decoded: 'System initialized. Listening on socket.', rawHex: '00 00 00 00 00', timestamp: new Date().toLocaleTimeString() }
    ];

    // Scoped DOM elements
    const txEl = container.querySelector('.vis-tx-counter') as HTMLElement;
    const rxEl = container.querySelector('.vis-rx-counter') as HTMLElement;
    const logEl = container.querySelector('.telemetry-hex-logger') as HTMLElement;
    const tabDecoded = container.querySelector('.log-tab-decoded') as HTMLButtonElement;
    const tabRaw = container.querySelector('.log-tab-raw') as HTMLButtonElement;
    const btnReset = container.querySelector('.btn-simulate-reset') as HTMLButtonElement;
    const linkPath = container.querySelector('.visual-link-path') as HTMLElement;
    const flowIndicator = container.querySelector('.telemetry-flow-indicator') as HTMLElement;
    const statusDot = container.querySelector('.telemetry-status-dot') as HTMLElement;
    const statusLabel = container.querySelector('.telemetry-status-label') as HTMLElement;
    const clientNode = container.querySelector('.visual-client-node') as HTMLElement;
    const selectInterface = container.querySelector('.telemetry-transport-select') as HTMLSelectElement;

    // Random HEX generator
    function getRandomHex(len: number) {
      const chars = '0123456789ABCDEF';
      let str = '';
      for (let i = 0; i < len; i++) {
        str += chars[Math.floor(Math.random() * 16)];
        if (i % 2 === 1 && i < len - 1) str += ' ';
      }
      return str;
    }

    // Update connection status animations
    function setConnectionState(state: 'secured' | 'connecting' | 'failed' | 'handshake') {
      if (!linkPath || !flowIndicator || !statusDot || !statusLabel) return;
      
      if (state === 'secured') {
        flowIndicator.innerText = 'SECURED';
        flowIndicator.className = 'telemetry-flow-indicator text-[8px] font-semibold text-emerald-500 bg-emerald-500/10 border border-emerald-500/20 px-1 rounded select-none uppercase';
        linkPath.className = 'visual-link-path flex-grow flex items-center justify-center gap-1 text-emerald-500 font-bold tracking-widest text-[8px]';
        statusDot.className = 'telemetry-status-dot w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse';
        statusLabel.innerText = 'ACTIVE (SECURED)';
        statusLabel.className = 'telemetry-status-label text-emerald-500 font-medium text-[8px]';
      } else if (state === 'connecting') {
        flowIndicator.innerText = 'CONNECTING';
        flowIndicator.className = 'telemetry-flow-indicator text-[8px] font-semibold text-text-primary/60 bg-text-primary/10 border border-text-primary/20 px-1 rounded select-none uppercase';
        linkPath.className = 'visual-link-path flex-grow flex items-center justify-center gap-1 text-text-primary/45 font-bold tracking-widest text-[8px]';
        statusDot.className = 'telemetry-status-dot w-1.5 h-1.5 rounded-full bg-text-primary/50 animate-ping';
        statusLabel.innerText = 'ESTABLISHING...';
        statusLabel.className = 'telemetry-status-label text-text-primary/60 font-medium text-[8px]';
      } else if (state === 'handshake') {
        flowIndicator.innerText = 'KEY_EXCHANGE';
        flowIndicator.className = 'telemetry-flow-indicator text-[8px] font-semibold text-amber-500 bg-amber-500/10 border border-amber-500/20 px-1 rounded select-none uppercase';
        linkPath.className = 'visual-link-path flex-grow flex items-center justify-center gap-1 text-amber-500 font-bold tracking-widest text-[8px] animate-pulse';
        statusDot.className = 'telemetry-status-dot w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse';
        statusLabel.innerText = 'HANDSHAKING...';
        statusLabel.className = 'telemetry-status-label text-amber-500 font-medium text-[8px]';
      }
    }

    // Print logs
    function renderLogs() {
      if (!logEl) return;
      logEl.innerHTML = '';
      logsBuffer.forEach(entry => {
        const line = document.createElement('div');
        
        let colorClass = 'text-text-primary/70';
        if (entry.type === 'tx') colorClass = 'text-text-heading';
        else if (entry.type === 'rx') colorClass = 'text-text-primary/75';
        else if (entry.type === 'sec') colorClass = 'text-emerald-500';
        else if (entry.type === 'conn') colorClass = 'text-amber-500';
        else if (entry.type === 'sys') colorClass = 'text-text-primary/50';

        line.className = colorClass;
        
        const timeStr = `[${entry.timestamp}]`;
        if (currentLogMode === 'decoded') {
          line.innerText = `${timeStr} ${entry.decoded}`;
        } else {
          const prefix = entry.type === 'tx' ? 'TX: ' : entry.type === 'rx' ? 'RX: ' : '';
          line.innerText = `${timeStr} ${prefix}${entry.rawHex}`;
        }
        
        logEl.appendChild(line);
      });
      logEl.scrollTop = logEl.scrollHeight;
    }

    function addLog(type: LogEntry['type'], decoded: string, rawHex: string) {
      const timestamp = new Date().toLocaleTimeString();
      logsBuffer.push({ type, decoded, rawHex, timestamp });
      if (logsBuffer.length > 25) logsBuffer.shift();
      renderLogs();
    }

    // Dropdown select
    if (selectInterface && clientNode) {
      selectInterface.addEventListener('change', () => {
        const val = selectInterface.value;
        if (val === 'tcp') {
          clientNode.innerText = 'ESP32';
          addLog('sys', 'Transport interface set to TCP/IP socket.', '01 02 A0 C0');
        } else if (val === 'uart') {
          clientNode.innerText = 'ARDUINO';
          addLog('sys', 'Transport interface set to UART Serial.', '01 02 A0 D0');
        } else {
          clientNode.innerText = 'ESP32';
          addLog('sys', 'Transport interface set to UDP datagram socket.', '01 02 A0 E0');
        }
      });
    }

    // Tabs
    if (tabDecoded && tabRaw) {
      tabDecoded.addEventListener('click', () => {
        currentLogMode = 'decoded';
        tabDecoded.className = 'log-tab-decoded px-1.5 py-0.5 rounded-[2px] text-[7px] font-bold tracking-wider cursor-pointer border-none text-text-heading bg-bg-panel transition-colors';
        tabRaw.className = 'log-tab-raw px-1.5 py-0.5 rounded-[2px] text-[7px] font-bold tracking-wider cursor-pointer border-none text-text-primary/65 hover:text-text-heading transition-colors bg-transparent';
        renderLogs();
      });

      tabRaw.addEventListener('click', () => {
        currentLogMode = 'raw';
        tabRaw.className = 'log-tab-raw px-1.5 py-0.5 rounded-[2px] text-[7px] font-bold tracking-wider cursor-pointer border-none text-text-heading bg-bg-panel transition-colors';
        tabDecoded.className = 'log-tab-decoded px-1.5 py-0.5 rounded-[2px] text-[7px] font-bold tracking-wider cursor-pointer border-none text-text-primary/65 hover:text-text-heading transition-colors bg-transparent';
        renderLogs();
      });
    }

    // Handshake execution
    function runHandshakeSimulation() {
      if (isSimulating) return;
      isSimulating = true;
      btnReset?.setAttribute('disabled', 'true');
      btnReset?.classList.add('opacity-50', 'cursor-not-allowed');
      logsBuffer.length = 0;
      
      setConnectionState('connecting');
      addLog('sys', 'Initializing USMP Session Reset...', '00 FF C0');

      setTimeout(() => {
        addLog('conn', '[CONN] Socket connection: OK. Host: 192.168.137.1:9000', '00 AA 11 22');
        setConnectionState('handshake');
      }, 800);

      setTimeout(() => {
        const ephemeralKey = getRandomHex(8);
        addLog('tx', '[TX] [Handshake Init] Client Hello (ECDH ephemeral key sent)', `CD AB 01 10 ${ephemeralKey}`);
        txCount++;
        if (txEl) txEl.innerText = txCount.toLocaleString();
      }, 1800);

      setTimeout(() => {
        const serverKey = getRandomHex(8);
        addLog('rx', '[RX] [Handshake Resp] Server Hello (ECDH key received)', `CD AB 02 10 ${serverKey}`);
        rxCount++;
        if (rxEl) rxEl.innerText = rxCount.toLocaleString();
      }, 2800);

      setTimeout(() => {
        addLog('sec', '[SEC] Keys generated: Derived AES_256_GCM key via HKDF-SHA256', '00 55 99 FF');
      }, 3600);

      setTimeout(() => {
        addLog('sec', '[SEC] Session verified. Channel SECURED and Active.', '00 BB 00 BB');
        setConnectionState('secured');
        isSimulating = false;
        btnReset?.removeAttribute('disabled');
        btnReset?.classList.remove('opacity-50', 'cursor-not-allowed');
      }, 4400);
    }

    btnReset?.addEventListener('click', runHandshakeSimulation);

    // Continuous payloads background generator
    setInterval(() => {
      if (isSimulating) return;
      const isTx = Math.random() > 0.45;
      
      if (isTx) {
        txCount++;
        if (txEl) txEl.innerText = txCount.toLocaleString();
        const payload = getRandomHex(4);
        addLog('tx', `[TX] Data Payload: Sent Encrypted Sensor Frame (${payload.length} B)`, `CD AB 03 30 ${payload}`);
      } else {
        rxCount++;
        if (rxEl) rxEl.innerText = rxCount.toLocaleString();
        addLog('rx', '[RX] Control Frame: Received Session Acknowledgment (ACK)', 'CD AB 04 20 A0 A0');
      }
    }, 7000);

    renderLogs();
  }

  // Bind all present panels independently
  function setupAllPanels() {
    document.querySelectorAll('.telemetry-panel-container').forEach(el => {
      const container = el as HTMLElement;
      if ((container as any).__telemetry_initialized) return;
      (container as any).__telemetry_initialized = true;
      initTelemetry(container);
    });
  }

  document.addEventListener('DOMContentLoaded', setupAllPanels);
  window.addEventListener('load', setupAllPanels);
</script>
