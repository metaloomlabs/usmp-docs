---
import LandingLayout from '../layouts/LandingLayout.astro';
import { Code } from 'astro:components';
import { monoTheme } from '../config/shikiTheme.mjs';
import TelemetryPanel from '../components/TelemetryPanel.astro';

const clientCode = `#include <usmp.h>

void app_main() {
    // 1. Initialize TCP transport & connection
    usmp_transport_t transport;
    usmp_transport_tcp_init(&transport, "192.168.1.100", 9000);

    usmp_t ctx = {0};
    usmp_connect(&ctx, &transport); // Auto mutual auth & X25519 key exchange

    // 2. Send AES-256-GCM encrypted payload
    char *payload = "{\\"temp\\": 24.5, \\"humidity\\": 62}";
    usmp_send(&ctx, (uint8_t *)payload, strlen(payload));

    // 3. Close the secure session gracefully
    usmp_close(&ctx);
}`;

const serverCode = `import asyncio
from usmp import USMPServer

async def handle_client(session):
    print(f"Secure session established with device: {session.device_id}")
    while True:
        # Wait for encrypted frames, automatically authenticated
        data = await session.recv()
        print(f"Decrypted payload: {data.decode()}")
        
        # Respond securely
        await session.send(b"ACK")

async def main():
    # Start the server gateway with a Pre-Shared Key (PSK)
    server = USMPServer(host="0.0.0.0", port=9000, psk=b"secure_psk_key_123")
    await server.start(handle_client)

async def main_run():
    await main()

asyncio.run(main_run())`;
---

<LandingLayout>
  <!-- Hero Section -->
  <section class="relative pt-24 pb-16 text-left max-w-[900px] mx-auto px-6">
    <div class="relative z-10">
      <!-- Status Badge indicator -->
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-bg-code border border-border-subtle rounded-sm text-[10px] font-mono font-bold tracking-wider text-text-heading uppercase mb-8 select-none">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-coral"></span>
        PROTOCOL_STATUS: SPECIFICATION_ACTIVE_V0.2.0
      </div>

      <h1 class="text-4xl sm:text-5xl font-heading font-extrabold tracking-tight text-text-heading leading-tight mb-4">
        Unified Secure Multi-transport Protocol
      </h1>
      
      <p class="text-base sm:text-lg text-text-primary font-semibold font-sans leading-relaxed mb-6">
        Secure, lightweight, transport-agnostic application session protocol for constrained embedded systems.
      </p>

      <p class="text-sm text-text-primary/75 font-sans leading-relaxed mb-8">
        USMP provides mutually authenticated, AES-256-GCM encrypted session framing for IoT microcontrollers and gateway nodes. Designed specifically for low-resource environments, it eliminates the handshake and footprint overhead of full TLS while ensuring forward secrecy and replay protection.
      </p>
      
      <div class="flex flex-wrap gap-4">
        <a 
          href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/docs`} 
          class="px-5 py-2.5 bg-text-heading text-bg-panel font-semibold rounded-sm text-xs tracking-wider uppercase transition-all hover:opacity-90 no-underline shadow-sm"
        >
          Initialize Core
        </a>
        <a 
          href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/docs/spec`} 
          class="px-5 py-2.5 bg-bg-panel border border-border-subtle text-text-primary font-semibold rounded-sm text-xs tracking-wider uppercase transition-colors hover:border-border-glow hover:text-text-heading no-underline"
        >
          Inspect Specification
        </a>
      </div>

      <!-- Monochromatic Metrics Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-12 text-left">
        <div class="border border-border-subtle bg-bg-panel p-5 rounded-sm">
          <span class="text-[9px] font-mono font-bold text-text-primary/50 uppercase tracking-widest block mb-1">SECURE BY DEFAULT</span>
          <span class="text-xs font-semibold text-text-heading font-mono">AES-256-GCM</span>
        </div>
        <div class="border border-border-subtle bg-bg-panel p-5 rounded-sm">
          <span class="text-[9px] font-mono font-bold text-text-primary/50 uppercase tracking-widest block mb-1">LIGHTWEIGHT</span>
          <span class="text-xs font-semibold text-text-heading font-mono">&lt;50 KB FOOTPRINT</span>
        </div>
        <div class="border border-border-subtle bg-bg-panel p-5 rounded-sm">
          <span class="text-[9px] font-mono font-bold text-text-primary/50 uppercase tracking-widest block mb-1">TRANSPORT AGNOSTIC</span>
          <span class="text-xs font-semibold text-text-heading font-mono">TCP, UART, BLE</span>
        </div>
        <div class="border border-border-subtle bg-bg-panel p-5 rounded-sm">
          <span class="text-[9px] font-mono font-bold text-text-primary/50 uppercase tracking-widest block mb-1">LANGUAGES</span>
          <span class="text-xs font-semibold text-text-heading font-mono">C, ARDUINO, PYTHON</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Interactive Code Switcher (Control Console) -->
  <section class="py-12 relative max-w-[900px] mx-auto px-6">
    <div>
      <div class="text-left mb-6 border-b border-border-subtle pb-3">
        <h2 class="text-sm font-heading font-bold text-text-heading tracking-wider uppercase mb-1">INTERACTIVE CONSOLE</h2>
        <p class="text-[10px] font-mono text-text-primary/60">BOILERPLATE CODE AND LIVE PROTOCOL HANDSHAKE SIMULATOR</p>
      </div>

      <!-- Console Window shell -->
      <div class="bg-bg-panel border border-border-subtle rounded-sm overflow-hidden">
        <!-- Tab controls header -->
        <div class="flex items-center justify-between px-4 bg-bg-code border-b border-border-subtle">
          <div class="flex font-mono">
            <button 
              class="tab-btn py-3 px-4 text-xs font-bold tracking-wider text-text-heading border-r border-border-subtle border-b-2 border-b-brand-accent bg-bg-panel transition-colors" 
              data-tab="client"
            >
              CLIENT.CPP
            </button>
            <button 
              class="tab-btn py-3 px-4 text-xs font-bold tracking-wider text-text-primary/60 border-r border-border-subtle hover:text-text-heading transition-colors" 
              data-tab="server"
            >
              GATEWAY.PY
            </button>
            <button 
              class="tab-btn py-3 px-4 text-xs font-bold tracking-wider text-text-primary/60 border-r border-border-subtle hover:text-text-heading transition-colors" 
              data-tab="simulator"
            >
              PROTOCOL SIMULATOR
            </button>
          </div>
          <div class="flex gap-1.5">
            <span class="w-2 h-2 rounded-full bg-border-subtle"></span>
            <span class="w-2 h-2 rounded-full bg-border-subtle"></span>
            <span class="w-2 h-2 rounded-full bg-border-subtle"></span>
          </div>
        </div>

        <!-- Code screens -->
        <div class="bg-bg-code relative">
          <div class="code-pane block" id="pane-client">
            <Code code={clientCode} lang="cpp" theme={monoTheme} />
          </div>
          <div class="code-pane hidden" id="pane-server">
            <Code code={serverCode} lang="python" theme={monoTheme} />
          </div>
          <div class="code-pane hidden p-6" id="pane-simulator">
            <TelemetryPanel />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="py-16 max-w-[900px] mx-auto px-6">
    <div>
      <div class="text-left mb-8 border-b border-border-subtle pb-3">
        <h2 class="text-sm font-heading font-extrabold text-text-heading tracking-wider uppercase">Cryptographic Specification</h2>
        <p class="text-[10px] text-text-primary/60 font-mono">USMP STRUCTURAL CHARACTERISTICS</p>
      </div>

      <!-- Grid layout -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Box 1 -->
        <div class="border border-border-subtle bg-bg-panel p-6 rounded-sm hover:border-brand-accent transition-colors">
          <h3 class="text-xs font-mono font-bold text-text-heading uppercase tracking-wider mb-2">Mutual Authentication</h3>
          <p class="text-xs text-text-primary/80 leading-relaxed">
            The handshake protocol authenticates both endpoints natively. Devices and gateways verify identities using Pre-Shared Keys (PSK) combined with cryptographically secure challenge nonces via HMAC-SHA256, eliminating unauthorized hardware connections.
          </p>
        </div>

        <!-- Box 2 -->
        <div class="border border-border-subtle bg-bg-panel p-6 rounded-sm hover:border-brand-accent transition-colors">
          <h3 class="text-xs font-mono font-bold text-text-heading uppercase tracking-wider mb-2">Forward Secrecy</h3>
          <p class="text-xs text-text-primary/80 leading-relaxed font-sans">
            Every secure session derives temporary, ephemeral X25519 keypairs. Future compromises of static keys on flash storage guarantee zero exposure of previously captured network sessions.
          </p>
        </div>

        <!-- Box 3 -->
        <div class="border border-border-subtle bg-bg-panel p-6 rounded-sm hover:border-brand-accent transition-colors">
          <h3 class="text-xs font-mono font-bold text-text-heading uppercase tracking-wider mb-2">AES-256-GCM</h3>
          <p class="text-xs text-text-primary/80 leading-relaxed font-sans">
            Enforced session framing encryption. Every single payload byte is encrypted and protected by a Galois integrity check tag, offering hardware-accelerated protection against active network tampering.
          </p>
        </div>

        <!-- Box 4 -->
        <div class="border border-border-subtle bg-bg-panel p-6 rounded-sm hover:border-brand-accent transition-colors">
          <h3 class="text-xs font-mono font-bold text-text-heading uppercase tracking-wider mb-2">Replay Protection</h3>
          <p class="text-xs text-text-primary/80 leading-relaxed">
            Per-session nonces joined with strict, monotonic, per-direction sequence numbers keep communication channels secure from packet injection and spoofing.
          </p>
        </div>
      </div>
    </div>
  </section>
</LandingLayout>

<script>
  // Console Tab switches
  const tabs = document.querySelectorAll('.tab-btn');
  const panes = document.querySelectorAll('.code-pane');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      // Deactivate tabs
      tabs.forEach(t => {
        t.classList.remove('text-text-heading', 'border-b-2', 'border-b-brand-accent', 'bg-bg-panel');
        t.classList.add('text-text-primary/60');
      });
      // Hide panes
      panes.forEach(p => {
        p.classList.remove('block');
        p.classList.add('hidden');
      });

      // Activate clicked
      tab.classList.add('text-text-heading', 'border-b-2', 'border-b-brand-accent', 'bg-bg-panel');
      tab.classList.remove('text-text-primary/60');

      const targetId = `pane-${tab.getAttribute('data-tab')}`;
      const targetPane = document.getElementById(targetId);
      if (targetPane) {
        targetPane.classList.remove('hidden');
        targetPane.classList.add('block');
      }
    });
  });
</script>
